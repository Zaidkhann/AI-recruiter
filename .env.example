# Copy to .env and fill in values: cp .env.example .env
# See README "Environment Variables" for details.

# Required for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recruiter_db

# Qdrant (vector store)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional API keys
GITHUB_TOKEN=
OPENAI_API_KEY=

# Authentication (JWT — demo mode bypasses auth)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend → backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auto-disqualify thresholds
DISQUALIFY_SEMANTIC_THRESHOLD=0.18
DISQUALIFY_OVERALL_THRESHOLD=0.20
